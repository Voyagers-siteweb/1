    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Voyagers Travel Agency | Premium Morocco</title>
    <!-- Tailwind CSS for Layout -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --burgundy: #630d16;
            --gold: #c5a059;
            --off-white: #fdfbf7;
            --charcoal: #121212;
            --deep-black: #0a0a0a;
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Dark Mode Variables */
        .dark {
            --off-white: var(--charcoal);
            --bg-body: var(--deep-black);
            --text-main: #e5e5e5;
            --card-bg: #1a1a1a;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--off-white);
            color: var(--charcoal);
            transition: var(--transition);
            overflow-x: hidden;
        }

        .dark body {
            background-color: var(--bg-body);
            color: var(--text-main);
        }

        h1, h2, h3, .luxury-font {
            font-family: 'Playfair Display', serif;
        }

        /* Moroccan Zellige Pattern Overlay */
        .zellige-pattern {
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0l15 30-15 30L15 30z' fill='%23c5a059' fill-opacity='0.05'/%3E%3C/svg%3E");
        }

        /* Custom UI Elements */
        .btn-gold {
            background-color: var(--gold);
            color: white;
            transition: var(--transition);
            border: 1px solid transparent;
        }

        .btn-gold:hover {
            background-color: transparent;
            border-color: var(--gold);
            color: var(--gold);
        }

        .btn-burgundy {
            background-color: var(--burgundy);
            color: white;
        }

        /* Arched Borders (Moroccan Style) */
        .arch-image {
            border-radius: 50% 50% 0 0;
            border: 4px solid var(--gold);
        }

        /* Parallax Hero */
        .hero-parallax {
            background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?auto=format&fit=crop&q=80&w=2000');
            background-attachment: fixed;
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
        }

        /* Glassmorphism Search Bar */
        .search-container {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 15px;
        }

        .dark .search-container {
            background: rgba(0, 0, 0, 0.4);
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--off-white); }
        ::-webkit-scrollbar-thumb { background: var(--burgundy); }

        .visa-card {
            transition: var(--transition);
            border: 1px solid rgba(197, 160, 89, 0.2);
        }

        .visa-card:hover {
            transform: translateY(-10px);
            border-color: var(--gold);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
    </style>
</head>
